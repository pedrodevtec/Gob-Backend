generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum ShopProductAssetKind {
  ITEM
  EQUIPMENT
  COINS
}

enum PaymentOrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
  CANCELED
}

enum GameplayDifficulty {
  EASY
  MEDIUM
  HARD
  ELITE
}

enum CharacterStatus {
  READY
  WOUNDED
  DEFEATED
}

enum TradeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
  EXPIRED
}

enum TradeParticipantSide {
  REQUESTER
  TARGET
}

enum TradeAssetType {
  ITEM
  EQUIPMENT
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  role          UserRole       @default(PLAYER)
  theme         String?
  characters    Character[]    @relation("UserToCharacter")
  paymentOrders PaymentOrder[]
}

model Character {
  id             String         @id @default(uuid())
  userId         String
  name           String
  level          Int            @default(1)
  xp             Int            @default(0)
  pvpRating      Int            @default(1000)
  pvpWins        Int            @default(0)
  pvpLosses      Int            @default(0)
  lastPvpAt      DateTime?
  currentHealth  Int            @default(100)
  status         CharacterStatus @default(READY)
  lastCheckpoint String?
  lastCombatAt   DateTime?
  lastRecoveredAt DateTime?
  avatarId       String?
  titleId        String?
  bannerId       String?
  posX           Float?
  posY           Float?
  posZ           Float?
  inventoryId    String?        @unique
  classId        String
  createdAt      DateTime       @default(now())

  user          User           @relation("UserToCharacter", fields: [userId], references: [id])
  inventory     Inventory?     @relation(fields: [inventoryId], references: [id])
  class         Class          @relation("ClassToCharacter", fields: [classId], references: [id])
  transactions  Transaction[]
  actionLogs    CharacterActionLog[]
  paymentOrders PaymentOrder[]
  rewardClaims  RewardClaim[]
  sentTrades    Trade[]        @relation("TradeRequesterCharacter")
  receivedTrades Trade[]       @relation("TradeTargetCharacter")
  pvpMatchesAsChallenger PvpMatch[] @relation("PvpMatchChallenger")
  pvpMatchesAsOpponent  PvpMatch[] @relation("PvpMatchOpponent")
  pvpWinsAsWinner       PvpMatch[] @relation("PvpMatchWinner")
  pvpLossesAsLoser      PvpMatch[] @relation("PvpMatchLoser")
}

model Inventory {
  id          String      @id @default(uuid())
  coins       Int         @default(0)
  items       Item[]
  equipments  Equipment[]
  character   Character?
  characterId String?     @unique
}

model Item {
  id          String    @id @default(uuid())
  name        String
  value       Int
  category    String
  type        String
  img         String
  effect      String?
  levelRequirement Int?
  quantity    Int       @default(1)
  inventoryId String
  monsterId   String?

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  monster   Monster?  @relation
}

model Equipment {
  id          String    @id @default(uuid())
  name        String
  value       Int
  category    String
  type        String
  img         String
  effect      String?
  isEquipped  Boolean   @default(false)
  equippedAt  DateTime?
  inventoryId String

  inventory Inventory @relation(fields: [inventoryId], references: [id])
}

model Class {
  id          String      @id @default(uuid())
  name        String      @unique
  tier        Int         @default(1)
  evolvesFrom String?
  modifier    String
  description String
  passive     String?
  characters  Character[] @relation("ClassToCharacter")
}

model BountyHunt {
  id                 String             @id @default(uuid())
  title              String
  description        String?
  monsterId          String
  recommendedLevel   Int                @default(1)
  difficulty         GameplayDifficulty @default(EASY)
  reward             Int
  rewardXp           Int                @default(0)
  rewardItemName     String?
  rewardItemCategory String?
  rewardItemType     String?
  rewardItemImg      String?
  rewardItemEffect   String?
  rewardItemValue    Int?
  rewardItemQuantity Int                @default(1)
  timeLimit          DateTime
  status             String
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  monster Monster @relation(fields: [monsterId], references: [id])
}

model Monster {
  id         String  @id @default(uuid())
  name       String  @unique
  level      Int
  health     Int
  attack     Int
  defense    Int
  experience Int
  dropItemId String? @unique

  dropItem Item?         @relation(fields: [dropItemId], references: [id])
  bounties BountyHunt[]
}

model MissionDefinition {
  id                 String             @id @default(uuid())
  title              String
  description        String?
  difficulty         GameplayDifficulty @default(EASY)
  recommendedLevel   Int                @default(1)
  enemyName          String
  enemyLevel         Int
  enemyHealth        Int
  enemyAttack        Int
  enemyDefense       Int
  rewardXp           Int
  rewardCoins        Int
  rewardItemName     String?
  rewardItemCategory String?
  rewardItemType     String?
  rewardItemImg      String?
  rewardItemEffect   String?
  rewardItemValue    Int?
  rewardItemQuantity Int                @default(1)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model TrainingDefinition {
  id              String   @id @default(uuid())
  name            String
  description     String?
  trainingType    String
  xpReward        Int
  coinsReward     Int      @default(0)
  cooldownSeconds Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NpcDefinition {
  id                 String   @id @default(uuid())
  name               String
  role               String
  interactionType    String
  description        String?
  dialogue           String?
  xpReward           Int      @default(0)
  coinsReward        Int      @default(0)
  rewardItemName     String?
  rewardItemCategory String?
  rewardItemType     String?
  rewardItemImg      String?
  rewardItemEffect   String?
  rewardItemValue    Int?
  rewardItemQuantity Int      @default(1)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Transaction {
  id          String    @id @default(uuid())
  characterId String
  type        String
  value       Int
  createdAt   DateTime  @default(now())

  character Character @relation(fields: [characterId], references: [id])
}

model CharacterActionLog {
  id          String   @id @default(uuid())
  characterId String
  actionType  String
  referenceId String?
  outcome     String
  availableAt DateTime?
  metadata    String?
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])

  @@index([characterId, actionType, createdAt])
  @@index([characterId, actionType, referenceId, createdAt])
}

model ShopProduct {
  id             String               @id @default(uuid())
  slug           String               @unique
  name           String
  description    String?
  category       String
  type           String
  img            String
  effect         String?
  levelRequirement Int?
  assetKind      ShopProductAssetKind
  price          Int
  currency       String               @default("BRL")
  rewardCoins    Int                  @default(0)
  rewardQuantity Int                  @default(1)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  paymentOrders PaymentOrder[]
}

model PaymentOrder {
  id                String             @id @default(uuid())
  userId            String
  characterId       String
  productId         String
  quantity          Int
  unitPrice         Int
  totalPrice        Int
  currency          String             @default("BRL")
  status            PaymentOrderStatus @default(PENDING)
  provider          String?
  providerReference String?            @unique
  providerPaymentId String?            @unique
  failureReason     String?
  paidAt            DateTime?
  fulfilledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  character Character   @relation(fields: [characterId], references: [id])
  product   ShopProduct @relation(fields: [productId], references: [id])
}

model RewardClaim {
  id          String   @id @default(uuid())
  characterId String
  claimKey    String   @unique
  type        String
  value       Int
  metadata    String?
  claimedAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])
}

model Trade {
  id                   String      @id @default(uuid())
  requesterCharacterId String
  targetCharacterId    String
  offeredCoins         Int         @default(0)
  requestedCoins       Int         @default(0)
  status               TradeStatus @default(PENDING)
  note                 String?
  expiresAt            DateTime
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  requesterCharacter Character   @relation("TradeRequesterCharacter", fields: [requesterCharacterId], references: [id])
  targetCharacter    Character   @relation("TradeTargetCharacter", fields: [targetCharacterId], references: [id])
  assets             TradeAsset[]

  @@index([requesterCharacterId, status, createdAt])
  @@index([targetCharacterId, status, createdAt])
}

model TradeAsset {
  id         String               @id @default(uuid())
  tradeId    String
  side       TradeParticipantSide
  assetType  TradeAssetType
  assetId    String
  quantity   Int                  @default(1)
  createdAt  DateTime             @default(now())

  trade Trade @relation(fields: [tradeId], references: [id])

  @@index([tradeId, side])
}

model PvpMatch {
  id                   String   @id @default(uuid())
  challengerCharacterId String
  opponentCharacterId   String
  winnerCharacterId     String
  loserCharacterId      String
  challengerRatingBefore Int
  challengerRatingAfter  Int
  opponentRatingBefore   Int
  opponentRatingAfter    Int
  createdAt             DateTime @default(now())

  challengerCharacter Character @relation("PvpMatchChallenger", fields: [challengerCharacterId], references: [id])
  opponentCharacter   Character @relation("PvpMatchOpponent", fields: [opponentCharacterId], references: [id])
  winnerCharacter     Character @relation("PvpMatchWinner", fields: [winnerCharacterId], references: [id])
  loserCharacter      Character @relation("PvpMatchLoser", fields: [loserCharacterId], references: [id])

  @@index([createdAt])
  @@index([winnerCharacterId, createdAt])
}
